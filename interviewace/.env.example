# InterviewAce Environment Configuration
# Make a copy of this file and rename it to ".env"

# REQUIRED: Your Gemini API Key
# Get one from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# The specific Gemini model to use for the agent
# We use the native audio preview model for bidirectional voice streaming
AGENT_MODEL="gemini-2.5-flash-native-audio-preview"

# OPTIONAL: Set to "true" if you have configured Google Cloud credentials
# and want to use Firestore for session memory and grounding data.
# If "false", the app will use an in-memory fallback so you can run it locally instantly.
USE_FIRESTORE="false"

# OPTIONAL: Port for the FastAPI server
PORT=8080
